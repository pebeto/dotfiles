[user]
	email = pebeto99@gmail.com
	name = Jose Esparza
[gpg]
	format = ssh
[commit]
	gpgsign = true
[core]
	editor = nvim
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
[lfs]
	concurrenttransfers = 3
[lfs "customtransfer.xet"]
	path = git-xet
	args = transfer
	concurrent = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
# Commit signing is SSH-based and PER-MACHINE: each box has its own key, so the
# actual `user.signingkey` (and `gpg.ssh.allowedSignersFile`, safe.directory, etc.)
# live in ~/.gitconfig.local, written by signing-setup.sh. Loaded last so it wins.
# Run signing-setup.sh once per machine or commits fail with "need a signingkey".
[include]
	path = ~/.gitconfig.local
