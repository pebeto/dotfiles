{
    "title": "Microphone key",
    "rules": [
        {
            "description": "fn+F5 -> toggle microphone mute (not Dictation)",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "f5",
                        "modifiers": { "mandatory": ["fn"] }
                    },
                    "to": [
                        { "shell_command": "$HOME/.config/bin/mic-toggle.sh" }
                    ]
                }
            ]
        }
    ]
}
