# dunst configuration — see dunst(5) for the full reference. Only values
# that differ from upstream defaults are listed here.

[global]
    # Geometry
    width = 300
    origin = top-right
    offset = (10, 50)

    # Frame & spacing (Plan9 acme palette, shared with fuzzel)
    frame_width = 1
    frame_color = "#8888cc"
    corner_radius = 5
    padding = 8
    horizontal_padding = 8

    # Text
    font = JuliaMono 10
    format = "<b>%s</b>\n%b"
    show_age_threshold = 60
    ellipsize = middle

    # Icons — recursive lookup against Adwaita; legacy icon_path removed.
    enable_recursive_icon_lookup = true
    icon_theme = Adwaita
    min_icon_size = 32
    max_icon_size = 128

    # History
    sticky_history = yes
    history_length = 20

    # Misc
    dmenu = fuzzel --dmenu --prompt='dunst: '
    browser = /usr/bin/xdg-open
    always_run_script = true

    # Wayland — stay above fullscreen apps
    layer = top

    # Mouse
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#ffffea"
    foreground = "#666666"
    timeout = 10
    default_icon = dialog-information

[urgency_normal]
    background = "#ffffea"
    foreground = "#000000"
    timeout = 10
    override_pause_level = 30
    default_icon = dialog-information

[urgency_critical]
    background = "#900000"
    foreground = "#ffffff"
    frame_color = "#ff0000"
    timeout = 0
    override_pause_level = 60
    default_icon = dialog-warning
